<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <!-- Category -->
    <GeneCategoryDef>
        <defName>Eternal</defName>
        <label>eternal</label>
        <displayPriorityInXenotype>800</displayPriorityInXenotype>
    </GeneCategoryDef>
    
    <!-- Genes -->
    <GeneDef>
        <defName>EternalAging</defName>
        <label>eternal aging</label>
        <labelShortAdj>eternal-aging</labelShortAdj>
        <description>Carriers of this gene have triple the lifespan of a normal human. They begin to age slower starting at the age of 18. By the time they reach 200, their aging rate is reduced to just 5% of the normal rate.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <biologicalAgeTickFactorFromAgeCurve>
            <points>
                <li>(18, 1)</li>
                <li>(25, 0.8)</li>
                <li>(40, 0.5)</li>
                <li>(80, 0.2)</li>
                <li>(120, 0.1)</li>
                <li>(200, 0.05)</li>
            </points>
        </biologicalAgeTickFactorFromAgeCurve>
        <statFactors>
            <LifespanFactor>3</LifespanFactor>
        </statFactors>
    </GeneDef>

    <GeneDef>
        <defName>EternalToughness</defName>
        <label>eternal toughness</label>
        <labelShortAdj>eternal-toughness</labelShortAdj>
        <description>Carriers of this gene have enhanced physical resilience, making them more resistant to damage and injury.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <painFactor>0.25</painFactor>
        <statFactors>
            <Flammability>0.1</Flammability>
            <StaggerDurationFactor>0.5</StaggerDurationFactor>
            <IncomingDamageFactor>0.50</IncomingDamageFactor>
        </statFactors>
        <statOffsets>
            <ComfyTemperatureMin>-30</ComfyTemperatureMin>
            <ComfyTemperatureMax>30</ComfyTemperatureMax>
            <ArmorRating_Blunt>0.25</ArmorRating_Blunt>
            <ArmorRating_Sharp>0.25</ArmorRating_Sharp>
            <ArmorRating_Heat>0.25</ArmorRating_Heat>
            <PainShockThreshold>0.50</PainShockThreshold>
        </statOffsets>
        <damageFactors>
            <Flame>0.25</Flame>
        </damageFactors>
    </GeneDef>

    <GeneDef>
        <defName>EternalHealing</defName>
        <label>eternal healing system</label>
        <labelShortAdj>eternal-hs</labelShortAdj>
        <description>Carriers of this gene heal wounds at an absolutely absurd rate and any bleeding stops nearly instantly.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <preventPermanentWounds>false</preventPermanentWounds>
        <geneClass>Gene_Clotting</geneClass>
        <statFactors>
            <InjuryHealingFactor>4</InjuryHealingFactor>
        </statFactors>
        <capMods>
            <li>
                <capacity>BloodFiltration</capacity>
                <offset>0.5</offset>
            </li>
        </capMods>
    </GeneDef>

    <GeneDef>
        <defName>EternalImmunity</defName>
        <label>eternal immunity</label>
        <labelShortAdj>eternal-immunity</labelShortAdj>
        <description>Carriers of this gene have an enhanced immune system, making them resistant to diseases, sickness, and infections.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>110</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <foodPoisoningChanceFactor>0.25</foodPoisoningChanceFactor>
        <addictionChanceFactor>0.25</addictionChanceFactor>
        <statFactors>
            <ImmunityGainSpeed>2</ImmunityGainSpeed>
            <RawNutritionFactor>2</RawNutritionFactor>
            <CancerRate>0.25</CancerRate>
        </statFactors>
        <statOffsets>
            <ToxicResistance>0.75</ToxicResistance>
            <ToxicEnvironmentResistance>0.75</ToxicEnvironmentResistance>
        </statOffsets>
    </GeneDef>

    <GeneDef>
        <defName>EternalSpeed</defName>
        <label>eternal speed</label>
        <labelShortAdj>eternal-speed</labelShortAdj>
        <description>Carriers of this gene have increased movement speed.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <statOffsets>
            <MoveSpeed>3</MoveSpeed>
        </statOffsets>
        <capMods>
            <li>
                <capacity>BloodPumping</capacity>
                <offset>0.5</offset>
            </li>
        </capMods>
    </GeneDef>

    <GeneDef>
        <defName>EternalStrength</defName>
        <label>eternal strength</label>
        <labelShortAdj>eternal-strength</labelShortAdj>
        <description>Carriers of this gene have increased physical strength.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <statFactors>
            <MeleeDamageFactor>2</MeleeDamageFactor>
            <CarryingCapacity>2</CarryingCapacity>
        </statFactors>
    </GeneDef>

    <GeneDef>
        <defName>EternalReproduction</defName>
        <label>eternal reproduction</label>
        <labelShortAdj>eternal-reproduction</labelShortAdj>
        <description>Carriers of this gene have an enhanced reproductive system, making them more fertile and capable of producing more offspring.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <lovinMTBFactor>0.25</lovinMTBFactor>
        <customEffectDescriptions>
            <li>Lovin' is 4x as likely to occur</li>
        </customEffectDescriptions>
        <statFactors>
            <Fertility>3</Fertility>   
        </statFactors>
        <statOffsets>
            <PawnBeauty>3</PawnBeauty>
        </statOffsets>
    </GeneDef>

    <GeneDef>
        <defName>EternalPerception</defName>
        <label>eternal perception</label>
        <labelShortAdj>eternal-perception</labelShortAdj>
        <description>Carriers of this gene have enhanced perception, allowing them to see and hear better than normal.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <statFactors>
            <PawnTrapSpringChance>0.25</PawnTrapSpringChance>
        </statFactors>
        <statOffsets>
            <AimingDelayFactor>-0.25</AimingDelayFactor>
            <ShootingAccuracyPawn>2</ShootingAccuracyPawn>
            <MeleeDodgeChance>2</MeleeDodgeChance>
            <MeleeHitChance>2</MeleeHitChance>
        </statOffsets>
        <capMods>
            <li>
                <capacity>Hearing</capacity>
                <offset>0.5</offset>
            </li>
            <li>
                <capacity>Sight</capacity>
                <offset>0.5</offset>
            </li>
        </capMods>
    </GeneDef>

    <GeneDef>
        <defName>EternalIntellect</defName>
        <label>eternal intellect</label>
        <labelShortAdj>eternal-intellect</labelShortAdj>
        <description>Carriers of this gene have enhanced cognitive abilities, allowing them to think more clearly and process information faster.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Eternal</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-5</biostatMet>
        <biostatCpx>5</biostatCpx>
        <statFactors>
            <GlobalLearningFactor>1.25</GlobalLearningFactor>
            <LearningRateFactor>1.25</LearningRateFactor>
            <ResearchSpeed>1.25</ResearchSpeed>
            <WorkSpeedGlobal>1.25</WorkSpeedGlobal>
            <HackingSpeed MayRequire="ludeon.rimworld.ideology">1.25</HackingSpeed>
        </statFactors>
        <statOffsets>
            <MentalBreakThreshold>-0.25</MentalBreakThreshold>
            <SocialImpact>0.25</SocialImpact>
            <TameAnimalChance>0.25</TameAnimalChance>
            <TrainAnimalChance>0.25</TrainAnimalChance>
            <NegotiationAbility>0.25</NegotiationAbility>
            <ConversionPower MayRequire="ludeon.rimworld.ideology">0.25</ConversionPower>
        </statOffsets>
    </GeneDef>
</Defs>