<?xml version="1.0" encoding="UTF-8"?>
<Defs>

    <!-- Stat -->
    <StatDef>
        <defName>Eternal_Percentage</defName>
        <label>eternal percentage</label>
        <description>Represents the percentage of eternal traits possessed by an individual.</description>
        <category>BasicsPawn</category>
        <defaultBaseValue>0</defaultBaseValue>
        <hideAtValue>0</hideAtValue>
        <minValue>0</minValue>
        <toStringStyle>PercentZero</toStringStyle>
        <displayPriorityInCategory>1000</displayPriorityInCategory>
    </StatDef>

    <StatDef>
        <defName>Test_stat</defName>
        <label>test stat</label>
        <description>Represents the test stat for an individual.</description>
        <category>BasicsPawn</category>
        <defaultBaseValue>0</defaultBaseValue>
        <hideAtValue>0</hideAtValue>
        <minValue>0</minValue>
        <toStringStyle>PercentZero</toStringStyle>
        <displayPriorityInCategory>1000</displayPriorityInCategory>
    </StatDef>

    <GeneDef MayRequire="EBSG.Framework">
        <defName>balls</defName>
        <geneClass>EBSGFramework.HediffAdder</geneClass>
        <label>test casdore</label>
        <labelShortAdj>test-stat-core</labelShortAdj>
        <description>Test</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Testing</displayCategory>
        <displayOrderInCategory>10</displayOrderInCategory>
        <biostatMet>-2</biostatMet>
        <biostatCpx>2</biostatCpx>
        <statOffsets>
            <Test_stat>2</Test_stat>
        </statOffsets>
    </GeneDef>

    <GeneDef MayRequire="EBSG.Framework">
        <defName>TestCoreStat</defName>
        <geneClass>EBSGFramework.HediffAdder</geneClass>
        <label>test stat core</label>
        <labelShortAdj>test-stat-core</labelShortAdj>
        <description>Test</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Testing</displayCategory>
        <displayOrderInCategory>10</displayOrderInCategory>
        <biostatMet>-2</biostatMet>
        <biostatCpx>2</biostatCpx>
        <statOffsets>
            <Test_stat>2</Test_stat>
        </statOffsets>
        <modExtensions>
            <li Class="EBSGFramework.EBSGExtension">
                <hediffsToApply>
                    <li>
                        <hediff>Test-H-Stat</hediff>
                    </li>
                    <li>
                        <hediff>Test-H-Test</hediff>
                    </li>
                </hediffsToApply>
            </li>
        </modExtensions>
    </GeneDef>

    <HediffDef>
        <defName>applepie</defName>
        <label>hemogenic pawn</label>
        <description>This is a test hediff</description>
        <everCurableByItem>false</everCurableByItem>
        <initialSeverity>0.001</initialSeverity>
        <stages />
        <hediffClass>HediffWithComps</hediffClass>
        <scenarioCanAdd>false</scenarioCanAdd>
        <comps>
            <li Class="EBSGFramework.HediffCompProperties_SeverityByGenes">
                <baseSeverity>0.5</baseSeverity>
                <geneEffects>
                    <li>
                        <gene>Sleepy</gene>
                        <statFactor>InjuryHealingFactor</statFactor>
                    </li>
                </geneEffects>
            </li>
            <li Class="EBSGFramework.HediffCompProperties_DisplaySeverity">
                <prependString>Test % : </prependString>
                <appendString>%</appendString>
                <roundDigits>2</roundDigits>
            </li>
        </comps>
    </HediffDef>


    <HediffDef MayRequire="EBSG.Framework">
        <defName>Test-H-Stat</defName>
        <label>test-h-stat</label>
        <description>This hediff test</description>
        <hediffClass>HediffWithComps</hediffClass>
        <scenarioCanAdd>False</scenarioCanAdd>
        <isBad>False</isBad>
        <everCurableByItem>False</everCurableByItem>
        <initialSeverity>0.001</initialSeverity>
        <stages>
            <li>
                <statFactors>
                    <MoveSpeed>1.5</MoveSpeed>
                </statFactors>
                <multiplyStatChangesBySeverity>true</multiplyStatChangesBySeverity>
            </li>
        </stages>
        <comps>
            <li Class="EBSGFramework.HediffCompProperties_SeverityByOtherHediffSeverities">
                <baseSeverity>1</baseSeverity>
                <hediffSets>
                    <li>
                        <hediff>Test-H-Test</hediff>
                    </li>
                </hediffSets>
            </li>
        </comps>
    </HediffDef>

    <HediffDef MayRequire="EBSG.Framework">
        <defName>Test-H-Test</defName>
        <label>test-h-test</label>
        <description>This hediff test</description>
        <hediffClass>HediffWithComps</hediffClass>
        <scenarioCanAdd>False</scenarioCanAdd>
        <isBad>False</isBad>
        <everCurableByItem>False</everCurableByItem>
        <initialSeverity>0.001</initialSeverity>
        <comps>
            <li Class="EBSGFramework.HediffCompProperties_SeverityByGenes">
                <baseSeverity>0.75</baseSeverity>
                <geneEffects>
                    <li>
                        <gene>Sleepy</gene>
                        <statFactor>InjuryHealingFactor</statFactor>
                    </li>
                </geneEffects>
            </li>
            <li Class="EBSGFramework.HediffCompProperties_DisplaySeverity">
                <prependString>Test % : </prependString>
                <appendString>%</appendString>
                <roundDigits>2</roundDigits>
            </li>
        </comps>
    </HediffDef>

    <!-- Category -->
    <GeneCategoryDef>
        <defName>Testing</defName>
        <label>testing</label>
        <displayPriorityInXenotype>8000000000</displayPriorityInXenotype>
    </GeneCategoryDef>
    
    <!-- Genes -->
    <GeneDef MayRequire="EBSG.Framework">
        <defName>TestCore</defName>
        <geneClass>EBSGFramework.HediffAdder</geneClass>
        <label>test core</label>
        <labelShortAdj>test-core</labelShortAdj>
        <description>Carriers of this gene have enhanced physical resilience, making them more resistant to damage and injury.</description>
        <iconPath>G-IDK</iconPath>
        <displayCategory>Testing</displayCategory>
        <displayOrderInCategory>0</displayOrderInCategory>
        <biostatMet>-2</biostatMet>
        <biostatCpx>2</biostatCpx>
        <statOffsets>
            <Eternal_Percentage>0.1</Eternal_Percentage>
        </statOffsets>
        <modExtensions>
            <li Class="EBSGFramework.EBSGExtension">
                <hediffsToApply>
                    <li>
                        <hediff>Test-H-Core</hediff>
                    </li>
                    <li>
                        <hediff>Test-H-Power</hediff>
                    </li>
                </hediffsToApply>
            </li>
        </modExtensions>
    </GeneDef>

    <HediffDef ParentName="Test-H-Scaling" MayRequire="EBSG.Framework">
        <defName>Test-H-Core</defName>
        <label>test-h-core</label>
        <description>This hediff provides enhanced physical resilience to its host</description>
        <stages>
            <li>
                <statFactors>
                    <MoveSpeed>1</MoveSpeed>
                    <SocialImpact>1</SocialImpact>
                    <GlobalLearningFactor>1</GlobalLearningFactor>
                </statFactors>
                <!-- <multiplyStatChangesBySeverity>true</multiplyStatChangesBySeverity> -->
                <statFactorEffectMultiplier>Eternal_Percentage</statFactorEffectMultiplier>
            </li>
        </stages>
    </HediffDef>

